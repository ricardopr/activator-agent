# Notion integration — required for Intel Collector
# 1. Go to notion.so/my-integrations → New integration → copy the token
NEXT_PUBLIC_NOTION_API_KEY=secret_...

# 2. Create a Notion database with the schema below, then copy the database ID from the URL
#    URL format: notion.so/<workspace>/<DATABASE_ID>?v=...
# 3. In Notion, open the database → ··· → Connections → add your integration
NEXT_PUBLIC_NOTION_DATABASE_ID=your-database-id-here

# Required database schema:
#   Title        — title
#   Author       — text
#   AuthorRole   — text
#   ContentType  — select   (options: LinkedIn Post, LinkedIn Article, My Note)
#   RawContent   — text
#   Topics       — multi-select
#   Signal       — text
#   DateAdded    — date
#   WeekNumber   — number
